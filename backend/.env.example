# ===== InnovaHUAP 360 — Backend (.env) =====
# Copia este archivo a ".env" y completa los valores reales.
# NUNCA commitees el archivo ".env" con secretos reales.

NODE_ENV=development
PORT=3001
API_PREFIX=api

# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Base de datos PostgreSQL
DATABASE_URL=postgresql://innovahuap:innovahuap@localhost:5432/innovahuap360

# JWT — genera secretos fuertes y distintos en cada entorno, p. ej.:
#   openssl rand -hex 64
JWT_ACCESS_SECRET=changeme-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_REFRESH_TTL_DAYS=30

# SMTP (recuperación de contraseña, Banco de Ideas, notificaciones).
# En desarrollo sin Docker puedes usar Mailhog (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog)
# o apuntar directo al SMTP real. La contraseña real va SOLO en este archivo
# ".env" local (gitignored), nunca en ".env.example" ni en el código.
SMTP_HOST=mail.huap.online
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=operaciones@huap.online
SMTP_PASS=CAMBIAR_EN_ENV_LOCAL
SMTP_FROM=operaciones@huap.online
SMTP_FROM_NAME=InnovaHUAP 360

# InnovaIA (asistente de IA). provider=none deshabilita el módulo de forma segura.
# Para usar Google Gemini: INNOVAIA_PROVIDER=gemini y completar GEMINI_API_KEY abajo.
INNOVAIA_PROVIDER=none
INNOVAIA_API_KEY=

# Google Gemini (API Key creada en Google AI Studio). Solo se usa si
# INNOVAIA_PROVIDER=gemini. Nunca se expone al frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Usuario administrador inicial (solo lo usa `npm run prisma:seed`)
ADMIN_EMAIL=admin@innovahuap.local
ADMIN_PASSWORD=

# Usuario super_admin de respaldo (acceso de emergencia/soporte), también creado
# por el seed. Si se deja vacío, el seed genera una contraseña aleatoria y la
# imprime una sola vez en consola (mismo criterio que ADMIN_PASSWORD).
SUPER_ADMIN_EMAIL=admin@innovahuap360.local
SUPER_ADMIN_PASSWORD=

# Carpeta de almacenamiento de archivos subidos
UPLOADS_DIR=./uploads
