<div style="font-family: 'Hanken Grotesk', Arial, sans-serif; max-width: 520px; margin: auto;">
  <h2 style="color:#ed1d25;margin:0 0 4px;">InnovaHUAP 360 — Banco de Ideas</h2>
  <h3 style="color:#222;margin:0 0 12px;">Nueva idea en el Banco de Ideas</h3>
  <p>{{proponentName}} postuló una nueva idea: <strong>"{{title}}"</strong>.</p>
  <table style="font-size:13px;color:#333;border-collapse:collapse;margin:14px 0;">
    <tr><td style="padding:3px 8px 3px 0;color:#888;">N° de solicitud</td><td style="padding:3px 0;font-weight:bold;">{{folio}}</td></tr>
    <tr><td style="padding:3px 8px 3px 0;color:#888;">Unidad / servicio</td><td style="padding:3px 0;">{{unitName}}</td></tr>
  </table>
  <p>
    <a href="{{ideasUrl}}" style="background:#ed1d25;color:#fff;padding:10px 18px;border-radius:6px;text-decoration:none;display:inline-block;">
      Revisar en el Banco de Ideas
    </a>
  </p>
  <p style="color:#888;font-size:12px;margin-top:24px;">Comité de Innovación · HUAP · Posta Central</p>
</div>
