// InnovaHUAP 360 — Esquema de base de datos (PostgreSQL)
// Fase 5 del plan de migración. Tablas mínimas definidas en el prompt maestro.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== Identidad y acceso =====================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  initials        String
  position        String?
  isActive        Boolean   @default(true) @map("is_active")
  mustChangePass  Boolean   @default(false) @map("must_change_pass")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  roleId          String    @map("role_id")
  role            Role      @relation(fields: [roleId], references: [id])

  refreshTokens   RefreshToken[]
  resetTokens     PasswordResetToken[]
  auditLogs       AuditLog[]
  uploads         Upload[]
  committeeMembership CommitteeMember?

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "admin", "coordinador", "miembro_comite", "lector"
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "public_content.manage", "users.manage"
  description String?

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  replacedBy  String?   @map("replaced_by")
  ip          String?
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// ===================== Contenido público (CMS) =====================

enum ContentSection {
  HOME
  QUIENES_SOMOS
  POLITICA
  PORTAFOLIO
  OBSERVATORIO
  CONOCIMIENTO
  EVENTOS
  NOTICIA
  BANNER
}

model PublicContent {
  id          String         @id @default(uuid())
  section     ContentSection
  title       String
  slug        String         @unique
  excerpt     String?
  body        String?
  // Campos adicionales usados solo por la página "Quiénes Somos"
  // (section = QUIENES_SOMOS, slug = "quienes-somos", fila única).
  // Quedan null para el resto de las secciones del CMS genérico.
  secondaryBody String?      @map("secondary_body")
  mission       String?
  vision        String?
  purpose       String?
  // Campos adicionales para los "items" administrables de Política,
  // Observatorio y Eventos (cada item es una fila PublicContent con la
  // section correspondiente; itemType distingue el subtipo dentro de la
  // sección, ej. DOCUMENTO/PRINCIPIO/INDICADOR/EVENTO). Quedan null para
  // HOME/NOTICIA/BANNER y para la fila singular de cada encabezado.
  itemType        String?   @map("item_type")
  category        String?
  tags            String[]  @default([])
  linkUrl         String?   @map("link_url")
  eventDate       DateTime? @map("event_date")
  eventLocation   String?   @map("event_location")
  registrationUrl String?   @map("registration_url")
  documentUploadId String?  @unique @map("document_upload_id")
  documentUpload   Upload?  @relation(fields: [documentUploadId], references: [id], onDelete: SetNull)
  // Portafolio público (Contenido Público → Portafolio): publicación
  // independiente del seguimiento interno del proyecto (Project). Puede
  // referenciar opcionalmente un proyecto real solo para trazabilidad —
  // eliminar esta fila nunca borra ni modifica el Project relacionado.
  expectedBenefits String? @map("expected_benefits")
  relatedProjectId String? @map("related_project_id")
  relatedProject   Project? @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  imageUrl    String?        @map("image_url")
  isPublished Boolean        @default(false) @map("is_published")
  isFeatured  Boolean        @default(false) @map("is_featured")
  sortOrder   Int            @default(0) @map("sort_order")
  publishedAt DateTime?      @map("published_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([section, isPublished, sortOrder])
  @@map("public_content")
}

// ===================== "Quiénes Somos" — listas administrables =====================
// No se reutiliza `CommitteeMember`: esa tabla solo marca qué usuarios del
// sistema reciben notificaciones del Banco de Ideas. El roster público de
// "Quiénes Somos" es contenido editorial (puede incluir personas sin cuenta
// en el sistema), administrado desde Contenido Público.

model AboutMember {
  id            String   @id @default(uuid())
  name          String
  role          String                         // Cargo
  unit          String?                        // Servicio/unidad
  committeeRole String?  @map("committee_role") // Rol dentro del comité (ej. Coordinador/a)
  email         String?
  photoUploadId String?  @unique @map("photo_upload_id")
  photoUpload   Upload?  @relation(fields: [photoUploadId], references: [id], onDelete: SetNull)
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("about_members")
}

model AboutAxis {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("about_axes")
}

model AboutObjective {
  id          String   @id @default(uuid())
  title       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("about_objectives")
}

model AboutValue {
  id          String   @id @default(uuid())
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("about_values")
}

model AboutDocument {
  id           String   @id @default(uuid())
  name         String
  description  String?
  fileUploadId String   @unique @map("file_upload_id")
  fileUpload   Upload   @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)
  isPublished  Boolean  @default(false) @map("is_published")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isPublished, sortOrder])
  @@map("about_documents")
}

// ===================== Portafolio de proyectos =====================

enum ProjectStage {
  IDEA
  FACTIBILIDAD
  PRIORIZACION
  DESARROLLO
  PILOTO
  IMPLEMENTACION
  ESCALAMIENTO
  CIERRE
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
}

model Project {
  id          String       @id @default(uuid())
  name        String
  description String?
  category    String?
  stage       ProjectStage @default(IDEA)
  ownerName   String       @map("owner_name")
  sponsor     String?
  riskLevel   RiskLevel    @default(BAJO) @map("risk_level")
  kpiSummary  String?      @map("kpi_summary")
  dueDate     DateTime?    @map("due_date")
  isPublic    Boolean      @default(false) @map("is_public")
  // Curados solo para la vitrina pública (/portafolio vía Contenido Público
  // → Portafolio); no afectan la máquina de etapas ni la gestión interna.
  imageUrl    String?      @map("image_url")
  isFeatured  Boolean      @default(false) @map("is_featured")
  sortOrder   Int          @default(0) @map("sort_order")
  startDate   DateTime?    @map("start_date")
  progressPct Int?         @map("progress_pct")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tasks       ProjectTask[]
  feasibility Feasibility[]
  minutesItems MinuteProject[]
  ideas       Idea[]
  stageHistory ProjectStageHistory[]
  publicEntries PublicContent[]

  @@map("projects")
}

// Pipeline de Innovación — gobernanza de etapas: cada transición queda
// trazada (quién, cuándo, desde/hacia qué etapa) para medir tiempo de ciclo
// y sustentar las reglas de avance (ver ProjectsService.transitionStage).
model ProjectStageHistory {
  id          String        @id @default(uuid())
  projectId   String        @map("project_id")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStage   ProjectStage  @map("from_stage")
  toStage     ProjectStage  @map("to_stage")
  changedByName String?     @map("changed_by_name")
  note        String?
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([projectId])
  @@map("project_stage_history")
}

model ProjectTask {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  ownerInitials String @map("owner_initials")
  startOffsetDays Int  @map("start_offset_days")
  durationDays    Int  @map("duration_days")
  progressPct     Int  @default(0) @map("progress_pct")
  sortOrder       Int  @default(0) @map("sort_order")

  @@map("project_tasks")
}

// ===================== Unidades y servicios HUAP =====================
// Tabla maestra que reemplaza las listas estáticas de "unidad/servicio"
// usadas en formularios (Banco de Ideas, etc). Editable desde Administración,
// con importación masiva desde Excel.

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ideas     Idea[]

  @@map("units")
}

// Miembros del Comité que reciben notificaciones del Banco de Ideas. Es una
// tabla de relación liviana sobre `users` (no duplica identidad): solo marca
// quién está suscrito a las notificaciones del Comité y permite activarlo o
// desactivarlo sin tocar el rol del usuario.
model CommitteeMember {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("committee_members")
}

// ===================== Banco de Ideas =====================
// Embudo formal de captura de ideas: cualquiera postula vía portal público
// con la ficha oficial del Comité, que hace triage, comenta, decide y —si
// corresponde— la convierte en un Project real, sin perder trazabilidad.

enum IdeaStatus {
  RECIBIDA
  EN_REVISION
  OBSERVADA
  FACTIBILIDAD
  APROBADA
  RECHAZADA
  EN_EJECUCION
  CERRADA
}

enum IdeaProjectType {
  GESTION_CLINICA
  GESTION_ADMINISTRATIVA
  ACADEMICO_IDI
}

enum IdeaProjectStage {
  IDEA
  DESARROLLO
  PILOTO_IMPLEMENTACION
}

enum IdeaPriority {
  BAJA
  MEDIA
  ALTA
}

model Idea {
  id                 String           @id @default(uuid())
  // Datos del solicitante
  proponentName      String           @map("proponent_name")
  position           String // Cargo
  email              String
  phone              String
  unitId             String           @map("unit_id")
  unit               Unit             @relation(fields: [unitId], references: [id])
  // Información del proyecto
  projectType        IdeaProjectType  @map("project_type")
  projectStage       IdeaProjectStage @map("project_stage")
  title              String // Nombre del proyecto
  description        String
  jefaturaApproval   Boolean          @map("jefatura_approval")
  // Ficha técnica obligatoria (DOC/DOCX/PDF)
  fichaUploadId      String           @unique @map("ficha_upload_id")
  fichaUpload        Upload           @relation(fields: [fichaUploadId], references: [id])
  // Flujo
  status             IdeaStatus       @default(RECIBIDA)
  priority           IdeaPriority     @default(MEDIA)
  isFeatured         Boolean          @default(false) @map("is_featured")
  votes              Int              @default(0)
  triageNote         String?          @map("triage_note")
  resultingProjectId String?          @map("resulting_project_id")
  resultingProject   Project?         @relation(fields: [resultingProjectId], references: [id])
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  comments       IdeaComment[]
  statusHistory  IdeaStatusHistory[]

  @@index([status])
  @@index([unitId])
  @@map("ideas")
}

model IdeaComment {
  id         String   @id @default(uuid())
  ideaId     String   @map("idea_id")
  idea       Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  authorId   String?  @map("author_id")
  authorName String   @map("author_name")
  comment    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ideaId])
  @@map("idea_comments")
}

model IdeaStatusHistory {
  id            String      @id @default(uuid())
  ideaId        String      @map("idea_id")
  idea          Idea        @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  fromStatus    IdeaStatus? @map("from_status")
  toStatus      IdeaStatus  @map("to_status")
  changedByName String?     @map("changed_by_name")
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([ideaId])
  @@map("idea_status_history")
}

// ===================== Actas y acuerdos =====================

model Minute {
  id           String   @id @default(uuid())
  title        String
  sessionDate  DateTime @map("session_date")
  isExtraordinary Boolean @default(false) @map("is_extraordinary")
  attendeesCount  Int    @default(0) @map("attendees_count")
  attendeeInitials String[] @map("attendee_initials")
  documentUrl  String?  @map("document_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agreements   Agreement[]
  projects     MinuteProject[]

  @@map("minutes")
}

model MinuteProject {
  minuteId  String  @map("minute_id")
  projectId String  @map("project_id")
  minute    Minute  @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([minuteId, projectId])
  @@map("minute_projects")
}

enum AgreementState {
  PENDIENTE
  EN_CURSO
  CUMPLIDO
  VENCIDO
}

model Agreement {
  id           String         @id @default(uuid())
  minuteId     String         @map("minute_id")
  minute       Minute         @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  description  String
  responsible  String
  dueDate      DateTime?      @map("due_date")
  state        AgreementState @default(PENDIENTE)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("agreements")
}

// ===================== Factibilidad =====================

model Feasibility {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criterionName String @map("criterion_name")
  score       Int      // 0-100
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("feasibility")
}

// ===================== Conocimiento =====================

enum KnowledgeType {
  ACTA
  INFORME
  PRESENTACION
  RESOLUCION
  CONVENIO
  LECCION
  GUIA
  PUBLICACION
  DOCUMENTO
  MANUAL
  CASO_EXITO
  ARTICULO
  ENLACE
}

model KnowledgeItem {
  id          String        @id @default(uuid())
  title       String
  type        KnowledgeType
  folder      String?
  fileUrl     String?       @map("file_url")
  linkUrl     String?       @map("link_url")
  sizeBytes   Int?          @map("size_bytes")
  authorName  String?       @map("author_name")
  downloads   Int           @default(0)
  isPublic    Boolean       @default(false) @map("is_public")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("knowledge_items")
}

// ===================== Comunicaciones =====================

enum CommunicationStatus {
  EN_DISENO
  PROGRAMADA
  ACTIVA
  FINALIZADA
}

model Communication {
  id          String              @id @default(uuid())
  title       String
  channel     String              // e.g. "Email · Intranet"
  status      CommunicationStatus @default(EN_DISENO)
  scheduledAt DateTime?           @map("scheduled_at")
  metrics     Json?               // lecturas, apertura, alcance, etc.
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("communications")
}

// ===================== Archivos =====================

model Upload {
  id           String   @id @default(uuid())
  originalName String   @map("original_name")
  storedName   String   @unique @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  uploadedById String?  @map("uploaded_by_id")
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  ideaFicha    Idea?
  aboutMemberPhoto  AboutMember?
  aboutDocumentFile AboutDocument?
  publicContentDocument PublicContent?

  @@map("uploads")
}

// ===================== Auditoría =====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. "auth.login", "public_content.publish"
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ===================== Configuración =====================

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
