{
  "name": "innovahuap360-backend",
  "private": true,
  "version": "1.0.0",
  "description": "InnovaHUAP 360 — API (NestJS + Prisma + PostgreSQL)",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\"",
