# ===== InnovaHUAP 360 — Variables para docker-compose =====
# Copia este archivo a ".env" en la raíz del repo y completa los valores
# reales antes de levantar el stack con `docker compose up`.
# NUNCA commitees el archivo ".env" con secretos reales.

NODE_ENV=development

# PostgreSQL
POSTGRES_USER=innovahuap
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=innovahuap360

# JWT — genera secretos fuertes y distintos en cada entorno, p. ej.:
#   openssl rand -hex 64
JWT_ACCESS_SECRET=changeme-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_REFRESH_TTL_DAYS=30

# Orígenes / URL pública del frontend (detrás del reverse proxy Nginx)
CORS_ORIGINS=http://localhost
FRONTEND_URL=http://localhost

# HTTPS (Let's Encrypt) — opcional, solo se usa si se levanta con
# docker-compose.https.yml (ver README_PREPROD.md sección 9). Dejar vacío
# mientras el ambiente sea solo HTTP.
DOMAIN_NAME=
CERTBOT_EMAIL=

# SMTP — en desarrollo se usa Mailhog (perfil "dev", sin auth). En
# producción usar el proveedor SMTP real y colocar la contraseña SOLO en
# el archivo ".env" local/preproductivo (nunca en este .example ni en Git).
SMTP_HOST=mail.huap.online
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=operaciones@huap.online
SMTP_PASS=CAMBIAR_EN_ENV_LOCAL
SMTP_FROM=operaciones@huap.online
SMTP_FROM_NAME=InnovaHUAP 360

# InnovaIA (asistente de IA). provider=none deshabilita el módulo de forma segura.
INNOVAIA_PROVIDER=none
INNOVAIA_API_KEY=

# Usuario administrador inicial creado por el seed
ADMIN_EMAIL=admin@innovahuap.local
ADMIN_PASSWORD=changeme-temp-password

# Usuario super_admin de respaldo (acceso de emergencia/soporte), también creado
# por el seed. Si se deja vacío, el seed genera una contraseña aleatoria y la
# imprime una sola vez en los logs del backend (mismo criterio que ADMIN_PASSWORD).
# Definirla explícitamente aquí antes del primer despliegue.
SUPER_ADMIN_EMAIL=admin@innovahuap360.local
SUPER_ADMIN_PASSWORD=changeme-temp-password

RUN_SEED=true
